{
  "name": "osdev-tools",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "clean": "rimraf dist",

    "build:html-js": "copyfiles -u 1 \"src/**/*.{html,js,png,svg}\" dist",
    "build:css": "tailwindcss -i ./src/style.css -o ./dist/style.css",
    "build": "npm run clean && npm run build:html-js && npm run build:css -- --minify",

    "watch:html-js":  "onchange \"src/**/*.{html,js,png,svg}\" -- npm run build:html-js",
    "watch:css": "tailwindcss -i ./src/style.css -o ./dist/style.css --watch",

    "serve": "live-server dist --port=8000",

    "dev": "npm run clean && npm run build:html-js && concurrently \"npm run watch:html-js\" \"npm run watch:css\" \"npm run serve\""
  },
  "keywords": [],
  "author": "rickyadastra",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "basecoat-css": "^0.3.11",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "live-server": "^1.2.2",
    "onchange": "^7.1.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2"
  }
}
